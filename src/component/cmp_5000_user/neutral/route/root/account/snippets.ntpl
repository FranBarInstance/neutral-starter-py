{:* --- Login Change Form Snippet --- *:}
{:snip; user_0yt2sa:user_account-login-change-form >>
    {:fetch; |{:;user_0yt2sa->manifest->route:}/account/login/ajax/{:;LTOKEN:}|form||{:;local::current->forms->class:}| >>
        <div class="input-group">
            <span class="input-group-text {:snip; is-invalid:email :}"><i class="{:;local::x-icon-email:}"></i></span>
            <div class="form-floating">
                <select
                    id="user_account-login-email"
                    name="email"
                    class="form-select {:snip; is-invalid:email :}"
                    aria-label="{:trans; New login email :}"
                    data-forms-autoselect-option="{:;CONTEXT->POST->email:}"
                    {:bool; current_forms->user_account_login_change->rules->email->required >> required :}
                >
                    <option value="">{:trans; Select an email :}</option>
                    {:each; user_emails k email >>
                        <option value="{:&;email->email:}">{:&;email->email:}</option>
                    :}
                </select>
                <label for="user_account-login-email">{:trans; New login email :}</label>
            </div>
        </div>
        {:snip; error-msg:email :}
        <div class="{:;local::current->forms->field-spacing:}"></div>

        <div class="input-group">
            <span class="input-group-text {:snip; is-invalid:current_password :}"><i class="{:;local::x-icon-user-password:}"></i></span>
            <div class="form-floating">
                <input
                    type="password"
                    id="user_account-login-current-password"
                    name="current_password"
                    value="{:;CONTEXT->POST->current_password:}"
                    class="form-control {:snip; is-invalid:current_password :}"
                    placeholder="{:trans; Current password :}"
                    aria-label="{:trans; Current password :}"
                    minlength="{:;current_forms->user_account_login_change->rules->current_password->minlength:}"
                    maxlength="{:;current_forms->user_account_login_change->rules->current_password->maxlength:}"
                    pattern="{:;current_forms->user_account_login_change->rules->current_password->pattern:}"
                    {:bool; current_forms->user_account_login_change->rules->current_password->required >> required :}
                >
                <label for="user_account-login-current-password">{:trans; Current password :}</label>
            </div>
        </div>
        {:snip; error-msg:current_password :}
        <div class="{:;local::current->forms->field-spacing:}"></div>

        <button
            type="submit"
            id="user_account-login-button-submit"
            name="send"
            class="btn btn-primary w-100"
            value="1"
        >{:trans; Change login :}</button>
    :}
:}

