{:* --- Password PIN Form Snippet --- *:}
{:snip; user_0yt2sa:user_account-password-pin-form >>
    {:fetch; |{:;user_0yt2sa->manifest->route:}/account/password/pin/ajax/{:;LTOKEN:}|form||{:;local::current->forms->class:}| >>
        <div class="input-group">
            <span class="input-group-text {:snip; is-invalid:email :}"><i class="{:;local::x-icon-email:}"></i></span>
            <div class="form-floating">
                <input
                    type="email"
                    id="user_account-password-pin-email"
                    name="email"
                    value="{:;CONTEXT->POST->email:}"
                    class="form-control {:snip; is-invalid:email :}"
                    placeholder="{:trans; Login email :}"
                    aria-label="{:trans; Login email :}"
                    minlength="{:;current_forms->user_account_password_pin->rules->email->minlength:}"
                    maxlength="{:;current_forms->user_account_password_pin->rules->email->maxlength:}"
                    pattern="{:;current_forms->user_account_password_pin->rules->email->pattern:}"
                    {:bool; current_forms->user_account_password_pin->rules->email->required >> required :}
                >
                <label for="user_account-password-pin-email">{:trans; Login email :}</label>
            </div>
        </div>
        {:snip; error-msg:email :}
        <div class="{:;local::current->forms->field-spacing:}"></div>
        <button
            type="submit"
            id="user_account-password-pin-button-submit"
            name="send"
            class="btn btn-outline-primary w-100"
            value="1"
        >{:trans; Send PIN :}</button>
    :}
:}

{:* --- Password Change Form Snippet --- *:}
{:snip; user_0yt2sa:user_account-password-change-form >>
    {:fetch; |{:;user_0yt2sa->manifest->route:}/account/password/ajax/{:;LTOKEN:}|form||{:;local::current->forms->class:}| >>
        <div class="input-group">
            <span class="input-group-text {:snip; is-invalid:pin :}"><i class="{:;local::x-icon-pin:}"></i></span>
            <div class="form-floating">
                <input
                    type="text"
                    id="user_account-password-pin"
                    name="pin"
                    value="{:;CONTEXT->POST->pin:}"
                    class="form-control {:snip; is-invalid:pin :}"
                    placeholder="{:trans; PIN :}"
                    aria-label="{:trans; PIN :}"
                    minlength="{:;current_forms->user_account_password_change->rules->pin->minlength:}"
                    maxlength="{:;current_forms->user_account_password_change->rules->pin->maxlength:}"
                    pattern="{:;current_forms->user_account_password_change->rules->pin->pattern:}"
                    {:bool; current_forms->user_account_password_change->rules->pin->required >> required :}
                >
                <label for="user_account-password-pin">{:trans; PIN :}</label>
            </div>
        </div>
        {:snip; error-msg:pin :}
        <div class="{:;local::current->forms->field-spacing:}"></div>

        <div class="input-group">
            <span class="input-group-text {:snip; is-invalid:password :}"><i class="{:;local::x-icon-user-password:}"></i></span>
            <div class="form-floating">
                <input
                    type="password"
                    id="user_account-password"
                    name="password"
                    value="{:;CONTEXT->POST->password:}"
                    class="form-control {:snip; is-invalid:password :}"
                    placeholder="{:trans; New password :}"
                    aria-label="{:trans; New password :}"
                    minlength="{:;current_forms->user_account_password_change->rules->password->minlength:}"
                    maxlength="{:;current_forms->user_account_password_change->rules->password->maxlength:}"
                    pattern="{:;current_forms->user_account_password_change->rules->password->pattern:}"
                    {:bool; current_forms->user_account_password_change->rules->password->required >> required :}
                >
                <label for="user_account-password">{:trans; New password :}</label>
            </div>
        </div>
        {:snip; error-msg:password :}
        <div class="{:;local::current->forms->field-spacing:}"></div>

        <div class="input-group">
            <span class="input-group-text {:snip; is-invalid:rptpassword :}"><i class="{:;local::x-icon-user-password:}"></i></span>
            <div class="form-floating">
                <input
                    type="password"
                    id="user_account-rptpassword"
                    name="rptpassword"
                    value="{:;CONTEXT->POST->rptpassword:}"
                    class="form-control {:snip; is-invalid:rptpassword :}"
                    placeholder="{:trans; Repeat password :}"
                    aria-label="{:trans; Repeat password :}"
                    minlength="{:;current_forms->user_account_password_change->rules->rptpassword->minlength:}"
                    maxlength="{:;current_forms->user_account_password_change->rules->rptpassword->maxlength:}"
                    pattern="{:;current_forms->user_account_password_change->rules->rptpassword->pattern:}"
                    {:bool; current_forms->user_account_password_change->rules->rptpassword->required >> required :}
                >
                <label for="user_account-rptpassword">{:trans; Repeat password :}</label>
            </div>
        </div>
        {:snip; error-msg:rptpassword :}
        <div class="{:;local::current->forms->field-spacing:}"></div>

        <button
            type="submit"
            id="user_account-password-button-submit"
            name="send"
            class="btn btn-primary w-100"
            value="1"
        >{:trans; Change password :}</button>
    :}
:}

