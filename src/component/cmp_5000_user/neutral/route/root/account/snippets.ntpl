{:* --- Result Snippets --- *:}
{:snip; user_0yt2sa:user_account-password-pin-result: >>:}
{:snip; user_0yt2sa:user_account-password-pin-result:true >>
    <div class="alert alert-success">
        <p class="mb-0">{:trans; {:;user_account_password_pin->is_submit->result->message:} :}</p>
    </div>
:}
{:snip; user_0yt2sa:user_account-password-pin-result:false >>
