{:* --- Required Snippets for Forms --- *:}
{:!include; {:flg; require :} >> {:;forms_0yt2sa->path:}/neutral/snippets.ntpl :}

{:*
    Generate password PIN form field error snippets.
 *:}
{:+each; user_account_password_pin->error->field field msg >>
    {:+code;
        {:param; field >> {:;field:} :}
        {:param; msg >> {:;msg:} :}
        {:param; help-item-url >> {:;user_0yt2sa->manifest->route:}/help/user_account_password_pin-{:;field:} :}
        {:snip; forms:set-form-field-error :}
    :}
:}

{:*
    Generate password change form field error snippets.
