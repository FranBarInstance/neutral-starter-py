{:* --- Account Content Snippet --- *:}
{:snip; user_0yt2sa:user_account-content >>
    <div id="user_account-content">
        <div class="row g-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">{:trans; Change password :}</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                {:snip; user_0yt2sa:user_account-password-pin-container :}
                            </div>
                            <div class="col-12 col-md-6">
                                {:snip; user_0yt2sa:user_account-password-change-container :}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card">
                    <div class="card-header">{:trans; Change birthdate :}</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                {:snip; user_0yt2sa:user_account-birthdate-pin-container :}
                            </div>
                            <div class="col-12 col-md-6">
                                {:snip; user_0yt2sa:user_account-birthdate-change-container :}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="card">
                    <div class="card-header">{:trans; Change login :}</div>
                    <div class="card-body">
                        {:snip; user_0yt2sa:user_account-login-change-container :}
                        <div class="alert alert-secondary mt-3">
                            <p class="mb-0">
                                {:trans; Add your email here: :}
                                <a href="{:;user_0yt2sa->manifest->route:}/email" class="ms-1 alert-link">{:trans; Emails :}</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
:}
