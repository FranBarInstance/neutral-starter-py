

{:*
    Load locale file
    ----------------
*:}
{:!locale; #/locale-{:lang;:}.json :}
{:else; {:!locale; #/locale-en.json :} :}

{:*
    Disable carousel for all component routes
    -----------------------------------------
*:}
{:snip; current:template:body-carousel >> :}

{:*
    Include form snippets
    ---------------------
*:}
{:include; {:flg; require :} >> #/form-snippets.ntpl :}
