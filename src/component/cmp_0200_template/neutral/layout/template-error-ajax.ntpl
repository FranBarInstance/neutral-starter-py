<div class="text-center my-2">
    <h6 class="border-bottom pb-2">{:trans; Error loading this complement :}</h6>
    <p class="lead text-muted">{:;HTTP_ERROR->code:} - {:trans; {:;HTTP_ERROR->text:} :}</p>
    {:filled; HTTP_ERROR->param >>
        <p class="">{:trans; {:;HTTP_ERROR->param:} :}</p>
    :}
</div>
