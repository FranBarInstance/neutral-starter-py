{:*
    Lateral bar
*:}
{:snip; current:template:body-lateral-bar >>
    <div class="p-3">
        <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none border-bottom pb-3">
            <span class="fs-4 {:;x-icons->x-icon-webapp:} me-2 text-primary"></span>
            <span class="fs-5 fw-bold">Neutral TS</span>
        </a>
        <a href="https://github.com/FranBarInstance/" class="">
            <img src="{:;current->site->static:}img/neutral.png" width="100%" alt="Neutral TS logo">
        </a>
        <div class="mb-4 mt-4">
            <h6 class="text-uppercase text-muted small fw-bold mb-2">About</h6>
            <p class="small text-secondary mb-2">
                Modular starter kit for building Progressive Web Applications using <strong>Python (Flask)</strong> and <strong>Neutral TS</strong> templating.
            </p>
            <div class="d-flex flex-wrap gap-1">
                <span class="badge bg-primary-subtle text-primary-emphasis small">Flask</span>
                <span class="badge bg-success-subtle text-success-emphasis small">PWA</span>
                <span class="badge bg-info-subtle text-info-emphasis small">NTPL</span>
            </div>
        </div>

        <div class="mb-4">
            <h6 class="text-uppercase text-muted small fw-bold mb-2">Quick Links</h6>
            <ul class="list-unstyled mb-0">
                <li class="mb-2">
                    <a href="https://github.com/FranBarInstance/neutral-starter-py" target="_blank" class="d-flex align-items-center text-decoration-none">
                        <span class="{:;x-icons->x-icon-link-blank:} me-2"></span>
                        <span class="small">Repository</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="https://franbarinstance.github.io/neutral-starter-py/" target="_blank" class="d-flex align-items-center text-decoration-none">
                        <span class="{:;x-icons->x-icon-link-blank:} me-2"></span>
                        <span class="small">Documentation</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="https://github.com/FranBarInstance/neutralts" target="_blank" class="d-flex align-items-center text-decoration-none">
                        <span class="{:;x-icons->x-icon-link-blank:} me-2"></span>
                        <span class="small">Neutral TS</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="mb-4">
            <h6 class="text-uppercase text-muted small fw-bold mb-2">Projects</h6>
            <div class="vstack gap-2">
                <a href="https://github.com/FranBarInstance/bootstrap-dynamic-themes" target="_blank" class="list-group-item list-group-item-action border-0 px-2 py-2 rounded">
                    <div class="d-flex w-100 align-items-center justify-content-between">
                        <strong class="small">Bootstrap Dynamic Themes</strong>
                        <small class="text-muted">↗</small>
                    </div>
                    <div class="small text-muted">Dynamic themes for Bootstrap 5</div>
                </a>
                <a href="https://github.com/FranBarInstance/neutralts" target="_blank" class="list-group-item list-group-item-action border-0 px-2 py-2 rounded">
                    <div class="d-flex w-100 align-items-center justify-content-between">
                        <strong class="small">Neutral TS</strong>
                        <small class="text-muted">↗</small>
                    </div>
                    <div class="small text-muted">Template engine for the Web</div>
                </a>
                <a href="https://github.com/FranBarInstance/neutraltemplate" target="_blank" class="list-group-item list-group-item-action border-0 px-2 py-2 rounded">
                    <div class="d-flex w-100 align-items-center justify-content-between">
                        <strong class="small">Neutral TS Python</strong>
                        <small class="text-muted">↗</small>
                    </div>
                    <div class="small text-muted">Python package implementation</div>
                </a>
                <a href="https://github.com/FranBarInstance/neutral-starter-py" target="_blank" class="list-group-item list-group-item-action border-0 px-2 py-2 rounded">
                    <div class="d-flex w-100 align-items-center justify-content-between">
                        <strong class="small">Starter Py</strong>
                        <small class="text-muted">↗</small>
                    </div>
                    <div class="small text-muted">Flask PWA scaffold</div>
                </a>
                <a href="https://github.com/FranBarInstance/neutralts-docs" target="_blank" class="list-group-item list-group-item-action border-0 px-2 py-2 rounded">
                    <div class="d-flex w-100 align-items-center justify-content-between">
                        <strong class="small">Documentation</strong>
                        <small class="text-muted">↗</small>
                    </div>
                    <div class="small text-muted">Official docs & guides</div>
                </a>
            </div>
        </div>

        <div class="mb-3">
            <h6 class="text-uppercase text-muted small fw-bold mb-2">Features</h6>
            <ul class="list-unstyled small mb-0">
                <li class="d-flex align-items-center mb-1">
                    <span class="text-success me-2">✓</span>
                    <span>Component architecture</span>
                </li>
                <li class="d-flex align-items-center mb-1">
                    <span class="text-success me-2">✓</span>
                    <span>Security headers</span>
                </li>
                <li class="d-flex align-items-center mb-1">
                    <span class="text-success me-2">✓</span>
                    <span>i18n support</span>
                </li>
                <li class="d-flex align-items-center mb-1">
                    <span class="text-success me-2">✓</span>
                    <span>PWA ready</span>
                </li>
            </ul>
        </div>
    </div>
:}

{:^;:}
