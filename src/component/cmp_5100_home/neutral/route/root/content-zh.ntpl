{:* ─── Features Header ─── *:}
<div class="text-center mb-4">
    <p class="text-body-tertiary text-uppercase fw-semibold mb-1"
       style="letter-spacing:2px; font-size:.75rem">功能特点</p>
    <h2 class="fw-bold mb-2">您需要的一切</h2>
    <p class="text-body-secondary mx-auto mb-0" style="max-width:540px">
        生产就绪的基础设施，让您专注于构建产品，而不是样板代码。
    </p>
</div>

{:* ─── Features Grid ─── *:}
<div class="row g-4 mb-5">

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border rounded-4">
            <div class="card-body p-4">
                <div class="d-inline-flex align-items-center justify-content-center border rounded-3 mb-3"
                     style="width:48px;height:48px">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                         fill="currentColor" class="text-body-secondary" viewBox="0 0 16 16">
