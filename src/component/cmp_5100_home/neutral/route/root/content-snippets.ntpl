{:snip; current:template:body-hero >>
    <div class="bg-{:;current->theme->color:} py-3 p-md-5">
        <div class="container px-3 py-4">
            <div class="row align-items-center gy-4">
                <div class="col-lg-8">
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        <span class="badge rounded-pill bg-primary fw-semibold">Neutral TS</span>
                        <span class="badge rounded-pill bg-primary fw-semibold">Flask</span>
                        <span class="badge rounded-pill bg-primary fw-semibold">Open Source</span>
                        <span class="badge rounded-pill bg-primary fw-semibold">PWA</span>
                    </div>
                    <h1 class="display-3 fw-normal mb-3">{:trans; Neutral TS Starter Python :}</h1>
                    <p class="lead opacity-75 mb-4">{:trans; A modular, opinionated starter kit for building Progressive Web Applications using Python (Flask) on the backend and Neutral TS as a universal templating engine. :}</p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a class="btn btn-outline-light px-3 px-md-4" href="https://github.com/FranBarInstance/neutral-starter-py">{:trans; Get Started :}</a>
                        <a class="btn btn-outline-light px-3 px-md-4" href="https://franbarinstance.github.io/neutral-starter-py/">{:trans; Documentation :}</a>
                    </div>
                </div>
                <div class="col-lg-4 d-none d-lg-block">
                </div>
            </div>
        </div>
    </div>
:}

