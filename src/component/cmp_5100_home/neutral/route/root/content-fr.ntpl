{:* ─── Features Header ─── *:}
<div class="text-center mb-4">
    <p class="text-body-tertiary text-uppercase fw-semibold mb-1"
       >Fonctionnalités</p>
    <h2 class="fw-bold mb-2">Tout ce dont Vous Avez Besoin</h2>
    <p class="text-body-secondary mx-auto mb-0">
        Fondations prêtes pour la production afin que vous puissiez vous concentrer sur la construction de votre produit, pas sur le code réutilisable.
    </p>
</div>

{:* ─── Features Grid ─── *:}
<div class="row g-4 mb-5">

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border rounded-4">
            <div class="card-body p-4">
                <div class="d-inline-flex align-items-center justify-content-center border rounded-3 mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                         fill="currentColor" class="text-body-secondary" viewBox="0 0 16 16">
                        <path d="M6 2a.5.5 0 0 1 .47.33L10
                            12.036l1.53-4.208A.5.5 0 0 1
                            12 7.5h3.5a.5.5 0 0 1
                            0 1h-3.15l-1.88
                            5.17a.5.5 0 0
                            1-.94 0L6
                            3.964 4.47
                            8.171A.5.5 0 0 1
