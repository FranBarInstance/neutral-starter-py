                            0-1h3.15l1.88-5.17A.5.5
                            0 0 1 6 2z"/>
                    </svg>
                </div>
                <h3 class="h5 fw-bold mb-2">Architecture Modulaire</h3>
                <p class="text-body-secondary mb-0">
                    Système de composants extensibles plug-and-play. Évoluez des prototypes rapides vers
                    des applications complexes tout en maintenant une structure propre et découplée.
                </p>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border rounded-4">
            <div class="card-body p-4">
                <div class="d-inline-flex align-items-center justify-content-center border rounded-3 mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
                         fill="currentColor" class="text-body-secondary" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1
                            1 0 0 1-1 1H2a1 1 0 0
